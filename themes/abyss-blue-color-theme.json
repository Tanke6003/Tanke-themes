{
  "name": "Abyss Blue",
  "type": "dark",
  "semanticHighlighting": true,

  "semanticTokenColors": {
    "enumMember": { "foreground": "#89DDFF" },
    "variable.constant": { "foreground": "#E0AF68" },
    "variable.defaultLibrary": { "foreground": "#7AA2F7" },
    "parameter": { "foreground": "#D8D8D8" },
    "property": { "foreground": "#9AB8D0" },
    "type": { "foreground": "#E0AF68" }
  },

  "tokenColors": [
    { "name": "Comments", "scope": "comment, punctuation.definition.comment", "settings": { "fontStyle": "italic", "foreground": "#6D7E8C" } },
    { "name": "Keywords", "scope": "keyword, keyword.control, storage.type, storage.modifier", "settings": { "foreground": "#B7A6F6" } },
    { "name": "Operators", "scope": "keyword.operator", "settings": { "foreground": "#89DDFF" } },
    { "name": "Strings", "scope": "string", "settings": { "foreground": "#9CE8FF" } },
    { "name": "Numbers", "scope": "constant.numeric", "settings": { "foreground": "#E0AF68" } },
    { "name": "Booleans & Constants", "scope": "constant.language, constant.character, constant.other", "settings": { "foreground": "#E0AF68" } },
    { "name": "Variables", "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#E6BDBD" } },
    { "name": "Parameters (italic hint)", "scope": "variable.parameter", "settings": { "fontStyle": "italic", "foreground": "#D8D8D8" } },
    { "name": "Property", "scope": "variable.other.property, meta.object-literal.key", "settings": { "foreground": "#9AB8D0" } },
    { "name": "Functions", "scope": "entity.name.function, support.function, variable.function", "settings": { "foreground": "#7AA2F7" } },
    { "name": "Type & Class", "scope": "entity.name.type, entity.name.class, support.class", "settings": { "foreground": "#E0AF68" } },
    { "name": "Interface / Namespace", "scope": "entity.name.namespace, entity.name.type.interface", "settings": { "foreground": "#A6C3FF" } },
    { "name": "Punctuation", "scope": "punctuation, punctuation.separator, punctuation.definition", "settings": { "foreground": "#9CB0C2" } },
    { "name": "JSON keys", "scope": "support.type.property-name.json", "settings": { "foreground": "#7AA2F7" } },
    { "name": "RegExp", "scope": "string.regexp", "settings": { "foreground": "#89DDFF" } },
    { "name": "Decorators / Annotations", "scope": "meta.decorator, meta.annotation, entity.name.function.decorator", "settings": { "foreground": "#B7A6F6" } },
    { "name": "Markdown Headings", "scope": "markup.heading, entity.name.section.markdown", "settings": { "foreground": "#7AA2F7" } },
    { "name": "Bold", "scope": "markup.bold, punctuation.definition.bold", "settings": { "foreground": "#E0AF68" } },
    { "name": "Italic", "scope": "markup.italic, punctuation.definition.italic", "settings": { "foreground": "#B7A6F6" } }
  ],

