{
  "$schema": "vscode://schemas/color-theme",
  "name": "Rose Dusk",
  "type": "dark",
  "semanticHighlighting": true,
  "tokenColors": [
    {
      "name": "Comments",
      "scope": "comment, punctuation.definition.comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9C7080"
      }
    },
    {
      "name": "Keywords",
      "scope": "keyword, keyword.control, storage.type, storage.modifier",
      "settings": {
        "foreground": "#FF4FA3"
      }
    },
    {
      "name": "Keyword Operators",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#FF85C2"
      }
    },
    {
      "name": "Strings",
      "scope": "string",
      "settings": {
        "foreground": "#FFD4E8"
      }
    },
    {
      "name": "Numbers / Constants",
      "scope": "constant.numeric, constant.language, constant.character, constant.other",
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "name": "Functions",
      "scope": "entity.name.function, support.function, variable.function",
      "settings": {
        "foreground": "#FF9EC8"
      }
    },
    {
      "name": "Classes / Types",
      "scope": "entity.name.type, entity.name.class, support.class, support.type",
      "settings": {
        "foreground": "#FFAA44"
      }
    },
    {
      "name": "Variables",
      "scope": "variable, variable.other.readwrite",
      "settings": {
        "foreground": "#F5C6D8"
      }
    },
    {
      "name": "Parameters",
      "scope": "variable.parameter",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#F5E0EA"
      }
    },
    {
      "name": "Properties / Object keys",
      "scope": "variable.other.property, meta.object-literal.key, support.type.property-name",
      "settings": {
        "foreground": "#FFB8D4"
      }
    },
    {
      "name": "JSON Keys",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#FF4FA3"
      }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation, punctuation.separator, punctuation.definition",
      "settings": {
        "foreground": "#C9A0B0"
      }
    },
    {
      "name": "Regex",
      "scope": "string.regexp",
      "settings": {
        "foreground": "#FFD6F0"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": "meta.decorator, meta.annotation, entity.name.function.decorator",
      "settings": {
        "foreground": "#FF69B4"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": "markup.heading, entity.name.section.markdown",
      "settings": {
        "foreground": "#FF85C2"
      }
    },
    {
      "name": "Bold",
      "scope": "markup.bold, punctuation.definition.bold",
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "name": "Italic",
      "scope": "markup.italic, punctuation.definition.italic",
      "settings": {
        "foreground": "#FF4FA3"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag",
        "meta.tag",
        "meta.tag.html"
      ],
      "settings": {
        "foreground": "#FF85C2"
      }
    },
    {
      "name": "HTML Attribute Names",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FF4FA3"
      }
    },
    {
      "name": "HTML Attribute Values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#FFD4E8"
      }
    },
    {
      "name": "Angular Interpolation",
      "scope": [
        "meta.interpolation.angular",
        "source.ts.embedded.html"
      ],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "name": "Angular Directive",
      "scope": [
        "entity.other.attribute-name.angular",
        "entity.other.attribute-name.ng"
      ],
      "settings": {
        "foreground": "#FFD4E8"
      }
    }
  ],
