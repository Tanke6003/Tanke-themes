{
  "$schema": "vscode://schemas/color-theme",
  "name": "Cyber Void",
  "type": "dark",
  "semanticHighlighting": true,

  "semanticTokenColors": {
    "keyword":          { "foreground": "#FF1F71" },
    "type":             { "foreground": "#00FFCC" },
    "class":            { "foreground": "#00FFCC" },
    "interface":        { "foreground": "#00E5FF" },
    "enum":             { "foreground": "#00E5FF" },
    "enumMember":       { "foreground": "#FF8C42" },
    "variable.readonly":{ "foreground": "#FF8C42" },
    "property":         { "foreground": "#7EB3FF" },
    "function":         { "foreground": "#00E5FF" },
    "parameter":        { "foreground": "#D0E4FF" }
  },

  "tokenColors": [
    { "name": "Comments",           "scope": "comment, punctuation.definition.comment",                                       "settings": { "fontStyle": "italic", "foreground": "#2E4A6A" } },
    { "name": "Keywords",           "scope": "keyword, keyword.control, storage.type, storage.modifier",                      "settings": { "foreground": "#FF1F71" } },
    { "name": "Operators",          "scope": "keyword.operator",                                                               "settings": { "foreground": "#FFD700" } },
    { "name": "Strings",            "scope": "string",                                                                         "settings": { "foreground": "#A8FF3E" } },
    { "name": "Numbers",            "scope": "constant.numeric",                                                               "settings": { "foreground": "#FF8C42" } },
    { "name": "Constants",          "scope": "constant.language, constant.character, constant.other",                          "settings": { "foreground": "#FF8C42" } },
    { "name": "Variables",          "scope": "variable, variable.other.readwrite",                                             "settings": { "foreground": "#C8D8EC" } },
    { "name": "Parameters",         "scope": "variable.parameter",                                                             "settings": { "fontStyle": "italic", "foreground": "#D0E4FF" } },
    { "name": "Properties",         "scope": "variable.other.property, meta.object-literal.key, support.type.property-name",  "settings": { "foreground": "#7EB3FF" } },
    { "name": "JSON Keys",          "scope": "support.type.property-name.json",                                                "settings": { "foreground": "#FF1F71" } },
    { "name": "Functions",          "scope": "entity.name.function, support.function, variable.function",                      "settings": { "foreground": "#00E5FF" } },
    { "name": "Types & Classes",    "scope": "entity.name.type, entity.name.class, support.class, support.type",               "settings": { "foreground": "#00FFCC" } },
    { "name": "Namespace",          "scope": "entity.name.namespace, entity.name.type.interface",                              "settings": { "foreground": "#00E5FF" } },
    { "name": "Punctuation",        "scope": "punctuation, punctuation.separator, punctuation.definition",                     "settings": { "foreground": "#3A5A7A" } },
    { "name": "RegExp",             "scope": "string.regexp",                                                                  "settings": { "foreground": "#00E5FF" } },
    { "name": "Decorators",         "scope": "meta.decorator, meta.annotation, entity.name.function.decorator",                "settings": { "foreground": "#FF5CFF" } },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag.html", "entity.name.tag", "meta.tag", "meta.tag.html"],
      "settings": { "foreground": "#00E5FF" }
    },
    {
      "name": "HTML Attribute Names",
      "scope": ["entity.other.attribute-name.html", "entity.other.attribute-name"],
      "settings": { "foreground": "#FF1F71" }
    },
    {
      "name": "HTML Attribute Values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#A8FF3E" }
    },
    { "name": "Markdown Headings",  "scope": "markup.heading, entity.name.section.markdown",                                  "settings": { "foreground": "#00E5FF" } },
    { "name": "Bold",               "scope": "markup.bold, punctuation.definition.bold",                                       "settings": { "foreground": "#FF8C42" } },
    { "name": "Italic",             "scope": "markup.italic, punctuation.definition.italic",                                   "settings": { "foreground": "#FF1F71" } }
  ],

  "colors": {
    "editor.background":  "#0B0E18",
    "editor.foreground":  "#C8D8EC",
